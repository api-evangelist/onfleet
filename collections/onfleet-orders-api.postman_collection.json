  "info": {
    "_postman_id": "e779877e-fd9d-4bbc-bb21-273949f054a6",
    "name": "Onfleet Orders API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Orders represent a delivery workflow composed of a pair of tasks — a pickup\nand a corresponding dropoff — used by courier organizations and their\nclients in the Onfleet Connect network. The Orders API lets you quote,\ncreate, update, clone, cancel, and reject orders programmatically.\n\n\nContact Support:\n Name: Onfleet Support\n Email: support@onfleet.com",
      "type": "text/plain"
    }
  }

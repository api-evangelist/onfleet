  "info": {
    "_postman_id": "8bfaecc6-80a3-4c5d-98fe-71b696f483fc",
    "name": "Onfleet Webhooks API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Onfleet Webhooks API lets you register HTTPS URLs to receive\nreal-time event payloads for tasks, workers, route plans, and dispatch\noperations. Each webhook is bound to a single trigger ID (0-30); payloads\nare signed with the secret from /webhooks/secret.\n\n\nContact Support:\n Name: Onfleet Support\n Email: support@onfleet.com",
      "type": "text/plain"
    }
  }

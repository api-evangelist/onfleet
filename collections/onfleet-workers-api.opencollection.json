{
  "opencollection": "1.0.0",
  "info": {
    "name": "Onfleet Workers API",
    "version": "2.7"
  },
  "request": {
    "auth": {
      "type": "basic",
      "username": "{{username}}",
      "password": "{{password}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Workers",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Workers",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://onfleet.com/api/v2/workers",
            "params": [
              {
                "name": "filter",
                "value": "",
                "type": "query",
                "description": "Comma-separated list of fields to return."
              },
              {
                "name": "teams",
                "value": "",
                "type": "query",
                "description": "Comma-separated list of team IDs."
              },
              {
                "name": "states",
                "value": "",
                "type": "query",
                "description": "Comma-separated list of worker states (0=Offline, 1=On-duty Idle, 2=On-duty Active)."
              },
              {
                "name": "phones",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "List Workers"
        },
        {
          "info": {
            "name": "Create Worker",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://onfleet.com/api/v2/workers",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Create Worker"
        },
        {
          "info": {
            "name": "Get Single Worker",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://onfleet.com/api/v2/workers/:workerId",
            "params": [
              {
                "name": "workerId",
                "value": "",
                "type": "path"
              },
              {
                "name": "filter",
                "value": "",
                "type": "query"
              },
              {
                "name": "analytics",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Get Single Worker"
        },
        {
          "info": {
            "name": "Update Worker",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://onfleet.com/api/v2/workers/:workerId",
            "params": [
              {
                "name": "workerId",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Update Worker"
        },
        {
          "info": {
            "name": "Delete Worker",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://onfleet.com/api/v2/workers/:workerId",
            "params": [
              {
                "name": "workerId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Delete Worker"
        },
        {
          "info": {
            "name": "List Worker's Assigned Tasks",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://onfleet.com/api/v2/workers/:workerId/tasks",
            "params": [
              {
                "name": "workerId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "List Worker's Assigned Tasks"
        },
        {
          "info": {
            "name": "Get Worker's Route Delivery Manifest",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://onfleet.com/api/v2/workers/:workerId/deliveryManifest",
            "params": [
              {
                "name": "workerId",
                "value": "",
                "type": "path"
              },
              {
                "name": "googleApiKey",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Get Worker's Route Delivery Manifest"
        }
      ]
    }
  ],
  "bundled": true
}
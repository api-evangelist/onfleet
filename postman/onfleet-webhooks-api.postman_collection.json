{
  "info": {
    "_postman_id": "4b57660c-4883-4234-aa89-dc98ae9dbe80",
    "name": "Onfleet Webhooks API",
    "description": "The Onfleet Webhooks API lets you register HTTPS URLs to receive\nreal-time event payloads for tasks, workers, route plans, and dispatch\noperations. Each webhook is bound to a single trigger ID (0-30); payloads\nare signed with the secret from /webhooks/secret.\n\n\nContact Support:\n Name: Onfleet Support\n Email: support@onfleet.com",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "createdAt": "2026-06-05T15:13:34.000Z",
    "updatedAt": "2026-06-05T15:13:35.000Z",
    "lastUpdatedBy": "35240",
    "uid": "35240-4b57660c-4883-4234-aa89-dc98ae9dbe80"
  },
